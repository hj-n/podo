#!/usr/bin/env python3
"""Small, self-contained command surface for an installed Podo Workspace."""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path


sys.dont_write_bytecode = True
ROOT = Path(__file__).resolve().parents[2]
PODO = ROOT / ".podo"
sys.path.insert(0, str(PODO / "scripts"))

from context_store import ContextError, ContextStore  # noqa: E402
from knowledge_views import KnowledgeViews, ViewError  # noqa: E402
from migration_store import MigrationError, apply_plan, plan_migration, plan_rollback  # noqa: E402
from recovery_store import RecoveryError, RecoveryStore  # noqa: E402
from product_manager import ProductManagerError, update_workspace  # noqa: E402
from transaction_store import TransactionError, TransactionManager  # noqa: E402


def read_version() -> str:
    return (PODO / "VERSION").read_text(encoding="utf-8").strip()


def command_version() -> int:
    workspace_version = (ROOT / "WORKSPACE_VERSION").read_text(encoding="utf-8").strip()
    print(f"Podo {read_version()} (Workspace {workspace_version})")
    return 0


def command_validate(mode: str) -> int:
    validator = PODO / "scripts/validate_workspace.py"
    result = subprocess.run(
        [sys.executable, str(validator), str(ROOT), "--mode", mode],
        check=False,
    )
    return result.returncode


def command_hook_status() -> int:
    hook_path = ROOT / ".codex/hooks.json"
    entrypoint = PODO / "scripts/capture_event"
    installed = False
    try:
        hook = json.loads(hook_path.read_text(encoding="utf-8"))
        handler = hook["hooks"]["Stop"][0]["hooks"][0]
        installed = (
            handler.get("type") == "command"
            and handler.get("command") == "./.podo/scripts/capture_event"
            and entrypoint.is_file()
        )
    except (OSError, json.JSONDecodeError, KeyError, IndexError, TypeError):
        pass

    health_path = ROOT / ".podo-work/capture-health.json"
    capture_status = "not-diagnosed"
    if health_path.is_file():
        try:
            health = json.loads(health_path.read_text(encoding="utf-8"))
            if health.get("status") == "ready":
                capture_status = f"ready ({health.get('capture_id', 'verified capture')})"
            elif health.get("status") == "error":
                capture_status = f"error ({health.get('code', 'unknown')})"
        except (OSError, json.JSONDecodeError):
            capture_status = "error (invalid health receipt)"
    print(f"hook-installed: {'yes' if installed else 'no'}")
    print("hook-trust: unverified (review in Codex; Podo does not auto-approve trust)")
    print(f"capture: {capture_status}")
    return 0 if installed else 1


def capture_health() -> dict[str, str | None]:
    health_path = ROOT / ".podo-work/capture-health.json"
    if not health_path.is_file():
        return {
            "status": "not-diagnosed",
            "code": "PODO_CAPTURE_NOT_DIAGNOSED",
            "detail": "No successful local capture diagnosis exists yet.",
            "checked_at": None,
        }
    try:
        value = json.loads(health_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        return {
            "status": "error",
            "code": "PODO_CAPTURE_HEALTH_INVALID",
            "detail": str(error),
            "checked_at": None,
        }
    if not isinstance(value, dict) or value.get("status") not in {"ready", "error"}:
        return {
            "status": "error",
            "code": "PODO_CAPTURE_HEALTH_INVALID",
            "detail": "capture health receipt has an unsupported shape",
            "checked_at": None,
        }
    return {
        "status": str(value["status"]),
        "code": str(value.get("code")) if value.get("code") else None,
        "detail": str(value.get("detail")) if value.get("detail") else None,
        "checked_at": str(value.get("checked_at")) if value.get("checked_at") else None,
    }


def command_inbox(as_json: bool) -> int:
    store = ContextStore(ROOT)
    values = store.list_inbox()
    deferred = store.list_deferred()
    try:
        recovery_required = TransactionManager(ROOT).unfinished()
    except TransactionError as error:
        raise ContextError(error.code, error.detail) from error
    recovery_store = RecoveryStore(ROOT)
    product_recovery_required = recovery_store.unfinished_product_updates()
    migration_recovery_required = recovery_store.unfinished_migrations()
    recovery_diagnosis = (
        recovery_store.doctor()
        if recovery_required or product_recovery_required or migration_recovery_required
        else None
    )
    current_capture_health = capture_health()
    if as_json:
        print(
            json.dumps(
                {
                    "pending": values,
                    "deferred": deferred,
                    "recovery_required": recovery_required,
                    "product_recovery_required": product_recovery_required,
                    "migration_recovery_required": migration_recovery_required,
                    "recovery_diagnosis": recovery_diagnosis,
                    "capture_health": current_capture_health,
                },
                ensure_ascii=False,
                indent=2,
            )
        )
    elif not values and not deferred and not recovery_required and not product_recovery_required and not migration_recovery_required:
        print("Inbox is empty.")
        if current_capture_health["status"] != "ready":
            print(f"capture-warning: {current_capture_health['code']} {current_capture_health['detail']}")
    else:
        for value in values:
            print(f"{value['capture_id']} | {value['completeness']} | {value['user_preview']}")
        for value in deferred:
            print(f"{value['capture_id']} | deferred | {value['summary']}")
        for value in recovery_required:
            print(f"{value} | recovery-required")
        for value in product_recovery_required:
            print(f"{value} | product-recovery-required")
        for value in migration_recovery_required:
            print(f"{value} | migration-recovery-required")
        if recovery_diagnosis is not None:
            print(f"doctor | {recovery_diagnosis['status']} | {recovery_diagnosis['finding_count']} findings")
        if current_capture_health["status"] != "ready":
            print(f"capture-warning | {current_capture_health['code']} | {current_capture_health['detail']}")
    return 0


def command_doctor(as_json: bool) -> int:
    result = RecoveryStore(ROOT).doctor()
    if as_json:
        print(json.dumps(result, ensure_ascii=False, indent=2))
    else:
        print(f"Podo doctor: {result['status']} ({result['finding_count']} findings)")
        for finding in result["findings"]:
            print(f"{finding['severity'].upper()} {finding['code']} {finding['summary']}")
    return 0 if result["status"] == "healthy" else 1


def command_todos(args: argparse.Namespace) -> int:
    from datetime import date

    due_before = None
    if args.due_before:
        try:
            due_before = date.fromisoformat(args.due_before)
        except ValueError as error:
            raise ViewError("E_TODO_DATE", "--due-before must be YYYY-MM-DD") from error
    values = KnowledgeViews(ROOT).todos(
        due_before=due_before,
        state=args.state,
        include_closed=args.all,
    )
    if args.json:
        print(json.dumps({"todos": values, "count": len(values)}, ensure_ascii=False, indent=2))
    elif not values:
        print("No matching TODOs.")
    else:
        for value in values:
            marker = "x" if value["closed"] else " "
            timing = f" | Due {value['due']}" if value["due"] else ""
            if value["target"]:
                timing += f" | Target {value['target']}"
            print(f"[{marker}] {value['text']} | {value['state']}{timing}")
    return 0


def command_duplicates(as_json: bool) -> int:
    values = KnowledgeViews(ROOT).duplicate_lines()
    if as_json:
        print(json.dumps({"duplicates": values, "count": len(values)}, ensure_ascii=False, indent=2))
    elif not values:
        print("No exact cross-document duplicates found.")
    else:
        for value in values:
            locations = ", ".join(f"{item['path']}:{item['line']}" for item in value["locations"])
            print(f"{value['text']} | {locations}")
    return 0


def command_recover(as_json: bool, plan_id: str | None) -> int:
    store = RecoveryStore(ROOT)
    result = store.apply_recovery(plan_id) if plan_id else store.plan_recovery()
    if as_json:
        print(json.dumps(result, ensure_ascii=False, indent=2))
    elif plan_id:
        print(f"Recovery {result['status']}: {result['plan_id']}")
    elif result["status"] == "nothing-to-recover":
        print("Nothing to recover.")
    else:
        print(f"Recovery planning: {result['status']}")
        for plan in result["plans"]:
            print(f"{plan['plan_id']} | {plan['action']} | {plan['transaction_id']}")
    return 0 if result["status"] in {"planned", "nothing-to-recover", "applied", "already-applied"} else 1


def command_update(version: str | None) -> int:
    result = update_workspace(ROOT, version)
    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def command_migrate(args: argparse.Namespace) -> int:
    if args.migration_command == "rollback":
        result = plan_rollback(ROOT, args.backup)
    elif args.apply:
        result = apply_plan(ROOT, args.apply)
    elif args.version:
        result = plan_migration(ROOT, args.version)
    else:
        raise MigrationError(
            "E_MIGRATION_COMMAND",
            "use --version to plan, --apply with an exact plan ID, or rollback --backup",
        )
    if args.json:
        print(json.dumps(result, ensure_ascii=False, indent=2, sort_keys=True))
        return 0
    if result.get("kind") == "migration":
        print(f"MIGRATION_PLAN {result['plan_id']}")
        print(f"PRODUCT {result['from_product_version']} -> {result['to_product_version']}")
        print(f"WORKSPACE {result['from_workspace_version']} -> {result['to_workspace_version']}")
        for step in result["chain"]:
            print(f"CHANGE {step['description']}")
            for change in step["changes"]:
                print(f"  - {change}")
        for relative in result["affected_paths"]:
            print(f"AFFECTS {relative}")
        print(f"BACKUP .podo-backups/{result['backup_id']}")
        print(f"ROLLBACK {result['rollback']}")
        print(f"NEXT Review this plan, then run ./.podo/bin/podo migrate --apply {result['plan_id']}")
    elif result.get("kind") == "rollback":
        print(f"ROLLBACK_PLAN {result['plan_id']}")
        print(f"PRODUCT {result['from_product_version']} -> {result['to_product_version']}")
        print(f"WORKSPACE {result['from_workspace_version']} -> {result['to_workspace_version']}")
        for relative in result["affected_paths"]:
            print(f"OVERWRITES {relative}")
        for relative in result["changes_since_migration"]:
            print(f"CHANGED_SINCE_MIGRATION {relative}")
        print(f"SOURCE_BACKUP .podo-backups/{result['source_backup_id']}")
        print(f"SAFETY_BACKUP .podo-backups/{result['backup_id']}")
        print(f"NEXT Review this rollback plan, then run ./.podo/bin/podo migrate --apply {result['plan_id']}")
    elif result.get("outcome") == "committed":
        print(f"MIGRATED {result['from_product_version']} -> {result['to_product_version']}")
        print(f"WORKSPACE {result['from_workspace_version']} -> {result['to_workspace_version']}")
        print(f"BACKUP .podo-backups/{result['backup_id']}")
        print("NEXT Start a new Codex task and review .codex/hooks.json before trusting changed hooks.")
    elif result.get("outcome") == "rollback-committed":
        print(f"WORKSPACE_ROLLED_BACK {result['from_product_version']} -> {result['to_product_version']}")
        print(f"WORKSPACE {result['from_workspace_version']} -> {result['to_workspace_version']}")
        print(f"SOURCE_BACKUP .podo-backups/{result['source_backup_id']}")
        print(f"SAFETY_BACKUP .podo-backups/{result['safety_backup_id']}")
        print("NEXT Start a new Codex task and review .codex/hooks.json before trusting changed hooks.")
    else:
        print(json.dumps(result, ensure_ascii=False, indent=2, sort_keys=True))
    return 0


def command_context_apply(capture_id: str, request: Path) -> int:
    result = ContextStore(ROOT).apply(capture_id, request)
    print(json.dumps(result, ensure_ascii=False, indent=2))
    return 0


def command_context_discard(capture_id: str, reason: str) -> int:
    result = ContextStore(ROOT).discard(capture_id, reason)
    print(json.dumps(result, ensure_ascii=False, indent=2))
    return 0


def command_context_defer(capture_id: str, request: Path) -> int:
    result = ContextStore(ROOT).defer_capture(capture_id, request)
    print(json.dumps(result, ensure_ascii=False, indent=2))
    return 0


def command_context_resolve(
    deferred_id: str,
    capture_id: str,
    decision: str,
    request: Path | None,
) -> int:
    result = ContextStore(ROOT).resolve(deferred_id, capture_id, decision, request)
    print(json.dumps(result, ensure_ascii=False, indent=2))
    return 0


def main() -> None:
    parser = argparse.ArgumentParser(prog="podo")
    subparsers = parser.add_subparsers(dest="command", required=True)
    subparsers.add_parser("version")
    validate = subparsers.add_parser("validate")
    validate.add_argument(
        "--mode",
        choices=("installed-empty", "context-present", "synthetic-fixture"),
        default="context-present",
    )
    subparsers.add_parser("hook-status")
    doctor = subparsers.add_parser("doctor")
    doctor.add_argument("--json", action="store_true")
    todos = subparsers.add_parser("todos")
    todos.add_argument("--due-before")
    todos.add_argument("--state")
    todos.add_argument("--all", action="store_true")
    todos.add_argument("--json", action="store_true")
    duplicates = subparsers.add_parser("duplicates")
    duplicates.add_argument("--json", action="store_true")
    recover = subparsers.add_parser("recover")
    recover.add_argument("--json", action="store_true")
    recover.add_argument("--apply", metavar="PLAN_ID")
    update = subparsers.add_parser("update")
    update.add_argument("--version")
    migrate = subparsers.add_parser("migrate")
    migrate.add_argument("--version")
    migrate.add_argument("--apply", metavar="PLAN_ID")
    migrate.add_argument("--json", action="store_true")
    migration_commands = migrate.add_subparsers(dest="migration_command")
    rollback = migration_commands.add_parser("rollback")
    rollback.add_argument("--backup", required=True)
    rollback.add_argument("--json", action="store_true")
    inbox = subparsers.add_parser("inbox")
    inbox.add_argument("--json", action="store_true")
    context = subparsers.add_parser("context")
    context_commands = context.add_subparsers(dest="context_command", required=True)
    apply = context_commands.add_parser("apply")
    apply.add_argument("--capture", required=True)
    apply.add_argument("--request", required=True, type=Path)
    defer = context_commands.add_parser("defer")
    defer.add_argument("--capture", required=True)
    defer.add_argument("--request", required=True, type=Path)
    resolve = context_commands.add_parser("resolve")
    resolve.add_argument("--deferred", required=True)
    resolve.add_argument("--capture", required=True)
    resolve.add_argument("--decision", required=True, choices=("confirmed", "rejected"))
    resolve.add_argument("--request", type=Path)
    discard = context_commands.add_parser("discard")
    discard.add_argument("--capture", required=True)
    discard.add_argument("--reason", required=True, choices=("no-delta", "sensitive-data"))
    args = parser.parse_args()

    try:
        if args.command == "version":
            code = command_version()
        elif args.command == "validate":
            code = command_validate(args.mode)
        elif args.command == "hook-status":
            code = command_hook_status()
        elif args.command == "doctor":
            code = command_doctor(args.json)
        elif args.command == "todos":
            code = command_todos(args)
        elif args.command == "duplicates":
            code = command_duplicates(args.json)
        elif args.command == "recover":
            code = command_recover(args.json, args.apply)
        elif args.command == "update":
            code = command_update(args.version)
        elif args.command == "migrate":
            code = command_migrate(args)
        elif args.command == "inbox":
            code = command_inbox(args.json)
        elif args.context_command == "apply":
            code = command_context_apply(args.capture, args.request)
        elif args.context_command == "defer":
            code = command_context_defer(args.capture, args.request)
        elif args.context_command == "resolve":
            code = command_context_resolve(args.deferred, args.capture, args.decision, args.request)
        else:
            code = command_context_discard(args.capture, args.reason)
    except (ContextError, MigrationError, RecoveryError, ProductManagerError, ViewError) as error:
        print(f"ERROR {error.code} {error.detail}", file=sys.stderr)
        code = 1
    raise SystemExit(code)


if __name__ == "__main__":
    main()
