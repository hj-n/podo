#!/usr/bin/env python3
"""Phase 1 guard for the future transcript capture entrypoint.

This validates the Stop hook envelope and fails closed. Phase 3 replaces the
guard with a versioned transcript adapter and Event capture implementation.
"""

from __future__ import annotations

import json
import sys
from pathlib import Path


def fail(code: str, detail: str, exit_code: int) -> None:
    print(f"{code}|{detail}", file=sys.stderr)
    raise SystemExit(exit_code)


def main() -> None:
    try:
        payload = json.load(sys.stdin)
    except json.JSONDecodeError as error:
        fail("PODO_CAPTURE_INVALID_HOOK_INPUT", str(error), 65)

    contract_path = Path(__file__).resolve().parents[1] / "contracts/hook_stop.json"
    contract = json.loads(contract_path.read_text(encoding="utf-8"))
    missing = [field for field in contract["required_input"] if not payload.get(field)]
    if missing:
        fail("PODO_CAPTURE_INVALID_HOOK_INPUT", "missing=" + ",".join(missing), 65)
    if payload.get("hook_event_name") != contract["event"]:
        fail("PODO_CAPTURE_INVALID_HOOK_INPUT", "expected Stop hook", 65)

    fail(
        "PODO_CAPTURE_NOT_IMPLEMENTED",
        "Phase 1 defines the contract; Phase 3 implements versioned capture",
        78,
    )


if __name__ == "__main__":
    main()
