{
  "contract_version": 1,
  "path": ".podo/install-manifest.json",
  "manifest_version": 1,
  "required_fields": [
    "manifest_version",
    "product_version",
    "workspace_version",
    "source",
    "product_files"
  ],
  "product_file_fields": [
    "sha256",
    "mode"
  ],
  "manifest_is_product_owned": true,
  "manifest_is_not_self_hashed": true
}
